# PostHog — product analytics (renderer)
# Leave empty to disable analytics entirely
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — crash reporting (main process)
# Leave empty to disable crash reporting entirely
AUTODOC_SENTRY_DSN=

# Set to "1" to enable Sentry in development
AUTODOC_SENTRY_DEV=

# ---------------------------------------------------------------------------
# Self-hosting / distribution configuration
# See docs/SELF_HOSTING.md for a full walkthrough.
# ---------------------------------------------------------------------------

# Marks a build as an "official" AutoDoc build. Only the official CI/release
# pipeline should set this to "1". Local and fork builds must leave it empty,
# which makes them default to self-hosted services (no Duet-hosted defaults).
AUTODOC_OFFICIAL_BUILD=

# Calendar OAuth worker URL.
# Fork/dev builds must provide their own worker URL to enable calendar OAuth.
AUTODOC_AUTH_WORKER_URL=

# Base URL for the macOS Whisper runtime asset bundle.
# Fork/dev builds must host their own runtime assets and point here.
AUTODOC_MACOS_WHISPER_RUNTIME_ASSET_BASE_URL=

# Base URL for the Windows transcription asset bundle.
# Fork/dev builds must host their own runtime assets and point here.
AUTODOC_WINDOWS_TRANSCRIPTION_ASSET_BASE_URL=
