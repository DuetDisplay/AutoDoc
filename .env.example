# PostHog — product analytics (renderer)
# Leave empty to disable analytics entirely
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — crash reporting (main process)
# Leave empty to disable crash reporting entirely
AUTODOC_SENTRY_DSN=

# Set to "1" to enable Sentry in development
AUTODOC_SENTRY_DEV=

# Calendar OAuth worker URL.
# Fork/dev builds must provide their own worker URL to enable calendar OAuth.
AUTODOC_AUTH_WORKER_URL=
