{
  "name": "autodoc",
  "version": "0.1.11",
  "description": "Local-first meeting assistant",
  "license": "AGPL-3.0-only",
  "main": "./out/main/index.js",
  "author": "",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "build:mac-meeting-detector": "node scripts/build-mac-meeting-detector.js",
    "build:win-meeting-detector": "node scripts/build-win-meeting-detector.js",
    "prepare:python-runtime": "node scripts/prepare-python-runtime.js",
    "prepare:diarization-model": "node scripts/prepare-diarization-model.js",
    "dev:start:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/manage-dev-session.ps1 start",
    "dev:status:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/manage-dev-session.ps1 status",
    "dev:stop:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/manage-dev-session.ps1 stop",
    "dev:restart:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/manage-dev-session.ps1 restart",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "npm run build:win-meeting-detector && npm run build:mac-meeting-detector && electron-vite preview",
    "dev": "npm run build:win-meeting-detector && npm run build:mac-meeting-detector && electron-vite dev",
    "generate-icons": "node scripts/generate-icons.js",
    "build": "npm run prepare:python-runtime && npm run prepare:diarization-model && npm run generate-icons && npm run build:win-meeting-detector && npm run build:mac-meeting-detector && npm run typecheck && electron-vite build",
    "postinstall": "npm run build:win-meeting-detector && npm run build:mac-meeting-detector && electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir --publish never",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never",
    "release:win": "npm run build && electron-builder --win nsis --publish always",
    "release:mac": "npm run build && electron-builder --mac --publish always",
    "test": "vitest",
    "test:run": "vitest run",
    "test:main": "vitest --config vitest.main.config.mts",
    "test:main:run": "vitest run --config vitest.main.config.mts",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@sentry/electron": "^7.10.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "posthog-js": "^1.363.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/geist": "^5.0.0",
    "@fontsource-variable/geist-mono": "^5.0.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^2.1.8",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^25.0.1",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.1.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^2.1.8",
    "zustand": "^5.0.2"
  }
}
